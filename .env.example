PUBLIC_SITE_URL=https://free-ai-audio-transcriber.pages.dev
PUBLIC_GITHUB_URL=https://github.com/yangnan-web-projects/free-ai-audio-transcriber

# Optional. Use a Hugging Face-compatible mirror or your own model host if
# huggingface.co is slow or blocked in your deployment region.
PUBLIC_TRANSFORMERS_REMOTE_HOST=https://huggingface.co

# Optional. Serve downloaded model files from the same origin, for example:
# public/models/onnx-community/whisper-tiny/...
# Leave unset in production so models load from Hugging Face and cache in the browser.
# PUBLIC_TRANSFORMERS_LOCAL_MODEL_PATH=/models/
