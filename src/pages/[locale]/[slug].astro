---
import LocalizedSeoLanding from '@components/LocalizedSeoLanding.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAlternateLinks, localizedSeoLocales } from '@lib/localized-seo';

export function getStaticPaths() {
  const toolSlugs = ['audio-to-text', 'mp3-to-text', 'audio-to-srt'] as const;
  return localizedSeoLocales.flatMap((locale) =>
    toolSlugs.map((slug) => ({ params: { locale: locale.slug, slug }, props: { locale, slug } }))
  );
}

const { locale, slug } = Astro.props;
const page = locale.tools[slug];
const siteUrl = Astro.site ?? new URL(import.meta.env.PUBLIC_SITE_URL || 'https://free-ai-audio-transcriber.pages.dev');
const alternateLinks = [
  ...getAlternateLinks(siteUrl, (item) => `/${item.slug}/${slug}/`),
  { hreflang: 'x-default', href: new URL(`/${slug}`, siteUrl).toString() }
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonicalPath={`/${locale.slug}/${slug}/`}
  htmlLang={locale.htmlLang}
  alternateLinks={alternateLinks}
>
  <LocalizedSeoLanding locale={locale} toolSlug={slug} />
</BaseLayout>
